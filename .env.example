# ─── Data APIs ───────────────────────────────────────────────────
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Finnhub: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# ─── Broker (Alpaca) ─────────────────────────────────────────────
# Paper trading: https://app.alpaca.markets/paper-signup
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
# Set to "false" ONLY when ready for live trading
PAPER_TRADING=true

# ─── Notifications (opcional) ────────────────────────────────────
# Create a Telegram bot: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Bot Settings ────────────────────────────────────────────────
# Comma-separated list of symbols to trade
SYMBOLS=AAPL,MSFT
# Max position size as fraction of portfolio (0.05 = 5%)
MAX_POSITION_SIZE=0.05
# Execution time (ET) - 9:35 = 5 min after market open
EXECUTION_TIME_ET=09:35
